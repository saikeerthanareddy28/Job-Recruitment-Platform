# ============================================================
# JobPortal Environment Variables - EXAMPLE FILE
# ============================================================
# 1. Copy this file: cp .env.example .env
# 2. Replace all values marked with [CHANGE THIS]
# 3. Never commit the .env file to version control
#
# For production deployment on Render + Clever Cloud + Vercel,
# set these environment variables in each platform's dashboard.
# See DEPLOYMENT.md for full instructions.

# --- Database (Clever Cloud provides DATABASE_URL) ---
# Option A: Clever Cloud automatically sets DATABASE_URL.
# Option B: For local dev or split variables, use these:
DATABASE_URL=jdbc:mysql://host:3306/dbname?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true&createDatabaseIfNotExist=true
DB_HOST=localhost
DB_PORT=3306
DB_NAME=jobportal
DB_USERNAME=jobportal
DB_PASSWORD=jobportal123                   # [CHANGE THIS in production]

# --- JPA ---
JPA_DDL_AUTO=update                        # Use "validate" for strict production

# --- JWT Security ---
# Must be at least 32 characters - use a random string!
JWT_SECRET=YourSuperSecretJWTKeyHere_AtLeast32Chars  # [CHANGE THIS]
JWT_EXPIRATION=86400000                    # 24 hours in milliseconds
REFRESH_TOKEN_EXPIRATION=604800000         # 7 days in milliseconds

# --- Server ---
SERVER_PORT=8080

# --- CORS (comma-separated frontend URLs) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- File Upload Directory ---
UPLOAD_DIRECTORY=./uploads